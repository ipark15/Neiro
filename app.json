{
  "expo": {
    "name": "Neiro",
    "slug": "neiro",
    "scheme": "neiro",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "main": "expo-router/entry",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#EDE8DF"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.neiro.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#EDE8DF"
      },
      "package": "com.neiro.app",
      "edgeToEdgeEnabled": true
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro",
      "output": "static",
      "name": "Neiro",
      "shortName": "Neiro",
      "display": "standalone",
      "themeColor": "#EDE8DF",
      "backgroundColor": "#EDE8DF",
      "startUrl": "/"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-av",
        {
          "microphonePermission": "Neiro needs access to your microphone to record voice diary entries."
        }
      ],
      "expo-audio"
    ]
  }
}
